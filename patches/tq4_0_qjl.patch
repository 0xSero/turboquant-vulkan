+static void tq3_wht32(float * x, bool inverse) {
+    if (!inverse) {
+        for (int i = 0; i < QK_TQ3_0; ++i) {
+            x[i] *= tq3_signs[i];
+        }
+    }
+
+    for (int step = 1; step < QK_TQ3_0; step <<= 1) {
+        for (int i = 0; i < QK_TQ3_0; i += step * 2) {
+            for (int j = i; j < i + step; ++j) {
+                const float a = x[j];
+                const float b = x[j + step];
+                x[j] = a + b;
+                x[j + step] = a - b;
+            }
+        }
+    }
