+    float d = sqrtf(row_sumsq / (nb * QK_TQ3_0)) / tq3_centroid_rms;
+    if (d <= 0.0f) d = 1e-8f;
+    const float id = 1.0f / d;
+    const ggml_half dh = GGML_FP32_TO_FP16(d);
+
+    for (int64_t i = 0; i < nb; ++i) {
+        y[i].d = dh;
+        memset(y[i].qs, 0, sizeof(y[i].qs));
+        for (int j = 0; j < QK_TQ3_0; ++j) {
+            const uint8_t idx = tq3_quantize_scalar(rotated[i][j] * id);
+            const int bit = j * 3;
+            const int byte = bit / 8;
+            const int shift = bit % 8;
+            y[i].qs[byte] |= idx << shift;
+            if (shift > 5) {
+                y[i].qs[byte + 1] |= idx >> (8 - shift);
+            }
+        }
+    }
+    #undef TQ3_MAX_BLOCKS_PER_ROW
+}
