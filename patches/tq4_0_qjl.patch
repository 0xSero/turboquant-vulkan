+void quantize_row_tq3_0_ref(const float * GGML_RESTRICT x, block_tq3_0 * GGML_RESTRICT y, int64_t k) {
+    assert(k % QK_TQ3_0 == 0);
+    const int64_t nb = k / QK_TQ3_0;
+
+    // Rotate all blocks first (WHT per block; signs applied locally).
+    // Then compute ONE L2 norm across the whole row — aligning with TurboQuant's
+    // per-vector normalization (Zandieh et al. 2025, arXiv 2504.19874).
+    // This replaces per-block RMS scaling which amplified inter-block
+    // quantization drift in attention K/Q dot products.
+    //
+    // Memory: one float[nb][32] buffer on the stack cap by nb≤32 (row ≤ 1024 floats).
+    // For larger rows we chunk.
+    #define TQ3_MAX_BLOCKS_PER_ROW 32
+    if (nb > TQ3_MAX_BLOCKS_PER_ROW) {
+        // Fall back to per-block scale for very large rows (>1024 elements).
+        // Should never happen in practice for KV cache head_dim ≤ 256.
+        for (int64_t i = 0; i < nb; ++i) {
+            float rotated[QK_TQ3_0];
+            for (int j = 0; j < QK_TQ3_0; ++j) rotated[j] = x[i*QK_TQ3_0 + j];
+            tq3_wht32(rotated, false);
+            float sumsq = 0.0f;
+            for (int j = 0; j < QK_TQ3_0; ++j) sumsq += rotated[j] * rotated[j];
+            float d = sqrtf(sumsq / QK_TQ3_0) / tq3_centroid_rms;
+            if (d <= 0.0f) d = 1e-8f;
+            y[i].d = GGML_FP32_TO_FP16(d);
+            memset(y[i].qs, 0, sizeof(y[i].qs));
+            const float id = 1.0f / d;
+            for (int j = 0; j < QK_TQ3_0; ++j) {
+                const uint8_t idx = tq3_quantize_scalar(rotated[j] * id);
+                const int bit = j * 3; const int byte = bit / 8; const int shift = bit % 8;
+                y[i].qs[byte] |= idx << shift;
+                if (shift > 5) y[i].qs[byte + 1] |= idx >> (8 - shift);
+            }
+        }
+        return;
+    }
+
+    float rotated[TQ3_MAX_BLOCKS_PER_ROW][QK_TQ3_0];
+    float row_sumsq = 0.0f;
+
+    for (int64_t i = 0; i < nb; ++i) {
+        for (int j = 0; j < QK_TQ3_0; ++j) {
+            rotated[i][j] = x[i*QK_TQ3_0 + j];
+        }
+        tq3_wht32(rotated[i], false);
+        for (int j = 0; j < QK_TQ3_0; ++j) {
+            row_sumsq += rotated[i][j] * rotated[i][j];
+        }
+    }
