+    -0.17677669529663688f, -0.17677669529663688f,  0.17677669529663688f, -0.17677669529663688f,
+     0.17677669529663688f,  0.17677669529663688f, -0.17677669529663688f,  0.17677669529663688f,
+    -0.17677669529663688f,  0.17677669529663688f, -0.17677669529663688f, -0.17677669529663688f,
+     0.17677669529663688f, -0.17677669529663688f, -0.17677669529663688f,  0.17677669529663688f,
+     0.17677669529663688f, -0.17677669529663688f,  0.17677669529663688f, -0.17677669529663688f,
+    -0.17677669529663688f,  0.17677669529663688f,  0.17677669529663688f,  0.17677669529663688f,
+    -0.17677669529663688f, -0.17677669529663688f,  0.17677669529663688f, -0.17677669529663688f
