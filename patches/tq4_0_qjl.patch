+static uint8_t tq3_quantize_scalar(float x) {
+    uint8_t idx = 0;
+    for (int i = 0; i < 7; ++i) {
+        if (x > tq3_boundaries[i]) {
+            ++idx;
+        }
+    }
+    return idx;
